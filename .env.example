# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit it.

# GCP project where BigQuery data lives
GCP_PROJECT_ID=your-gcp-project-id

# Path to GCP service account JSON keyfile (if using service-account auth)
# Leave blank if using oauth (gcloud auth application-default login)
GCP_KEYFILE_PATH=

# dbt target dataset (output BigQuery dataset prefix)
DBT_DATASET=olist_dev
